{
    "name": "mariusz/php-logger",
    "description": "PSR-3 dual logger with file rotation, date-based structure and automatic anonymization of sensitive fields",
    "type": "library",
    "license": "MIT",
    "keywords": ["logger", "psr-3", "log", "file-rotation", "anonymization", "laravel", "symfony"],
    "homepage": "https://github.com/mafio69/php-logger",
    "authors": [
        {
            "name": "Mariusz Franciszczak",
            "email": "mariusz.franciszczak@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.1",
        "psr/log": "^3.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "dg/bypass-finals": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "Mariusz\\Logger\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Mariusz\\Logger\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Mariusz\\Logger\\Laravel\\LoggerServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit"
    }
}
